{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/ping.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "api/ping.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "0 8 */5 * *"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "github": {
    "enabled": true
  }
}